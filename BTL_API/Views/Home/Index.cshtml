@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- Hero -->
<section class="hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-lg-7">
                <h1>Công nghệ đỉnh cao,<br />giá cả hợp lý</h1>
                <p>Khám phá các sản phẩm điện thoại, phụ kiện công nghệ chính hãng mới nhất với chương trình ưu đãi hấp dẫn.</p>
                <a href="#products" class="hero-btn">
                    <i class="bi bi-grid"></i> Khám phá ngay
                </a>
            </div>
        </div>
    </div>
</section>

<!-- Featured Products Banner -->
<section class="featured-banner">
    <div class="container">
        <h2 class="section-title"><i class="bi bi-star-fill"></i> Sản phẩm nổi bật</h2>
        <div class="featured-scroll" id="featuredScroll">
            <div class="skeleton" style="width:260px;height:320px;border-radius:12px;flex-shrink:0"></div>
            <div class="skeleton" style="width:260px;height:320px;border-radius:12px;flex-shrink:0"></div>
            <div class="skeleton" style="width:260px;height:320px;border-radius:12px;flex-shrink:0"></div>
            <div class="skeleton" style="width:260px;height:320px;border-radius:12px;flex-shrink:0"></div>
            <div class="skeleton" style="width:260px;height:320px;border-radius:12px;flex-shrink:0"></div>
        </div>
    </div>
</section>

<!-- Products -->
<section class="page-container" id="products">
    <h2 class="section-title"><i class="bi bi-grid-3x3-gap-fill"></i> Sản phẩm</h2>

    <div class="category-pills" id="categoryPills">
        <div class="skeleton" style="width:80px;height:34px;border-radius:99px"></div>
        <div class="skeleton" style="width:100px;height:34px;border-radius:99px"></div>
        <div class="skeleton" style="width:90px;height:34px;border-radius:99px"></div>
    </div>

    <!-- Advanced Filters -->
    <div class="filter-bar" id="filterBar">
        <div class="filter-group">
            <label class="filter-label"><i class="bi bi-sort-down"></i> Sắp xếp</label>
            <select class="filter-select" id="filterSort">
                <option value="default">Mặc định</option>
                <option value="price-asc">Giá: Thấp → Cao</option>
                <option value="price-desc">Giá: Cao → Thấp</option>
                <option value="name-asc">Tên: A → Z</option>
                <option value="name-desc">Tên: Z → A</option>
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label"><i class="bi bi-tag"></i> Thương hiệu</label>
            <select class="filter-select" id="filterBrand">
                <option value="all">Tất cả</option>
            </select>
        </div>
        <div class="filter-group">
            <label class="filter-label"><i class="bi bi-cash-stack"></i> Giá</label>
            <div class="filter-price-range">
                <input type="number" class="filter-input" id="filterPriceMin" placeholder="Từ" min="0">
                <span class="filter-separator">–</span>
                <input type="number" class="filter-input" id="filterPriceMax" placeholder="Đến" min="0">
            </div>
        </div>
        <div class="filter-group">
            <label class="filter-toggle-label">
                <input type="checkbox" id="filterInStock">
                <span class="filter-toggle-text"><i class="bi bi-check-circle"></i> Còn hàng</span>
            </label>
        </div>
        <button class="filter-reset-btn" id="filterResetBtn" title="Xóa bộ lọc">
            <i class="bi bi-x-lg"></i> Xóa lọc
        </button>
    </div>

    <div class="filter-result-count" id="filterResultCount"></div>

    <div class="product-grid" id="productGrid"></div>
</section>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            loadStorefront();
            loadFeaturedProducts();
        });
    </script>
}