<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Cell Tech Admin</title>
    
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/admin-style.css" rel="stylesheet" asp-append-version="true" />
</head>
<body class="sb-nav-fixed">
    
    <partial name="_TopbarAdmin" />

    <div id="layoutSidenav">
        <partial name="_SidebarAdmin" />

        <div id="layoutSidenav_content">
            <main>
                <div class="container-fluid px-4 py-4">
                    
                    @RenderBody()

                </div>
            </main>
            
            <partial name="_FooterAdmin" />
        </div>
    </div>

    <script>
        // 1. Script cho Nút thu gọn Sidebar
        window.addEventListener('DOMContentLoaded', event => {
            const sidebarToggle = document.body.querySelector('#sidebarToggle');
            if (sidebarToggle) {
                sidebarToggle.addEventListener('click', event => {
                    event.preventDefault();
                    document.body.classList.toggle('sb-sidenav-toggled');
                });
            }
        });

        // 2. Script Phân quyền (Trạm gác bảo vệ)
        document.addEventListener("DOMContentLoaded", function () {
            const userRole = localStorage.getItem('Role');
            const currentPath = window.location.pathname.toLowerCase();

            // Chặn người lạ hoặc Khách hàng đi lạc vào Admin
            if (!userRole || userRole === 'Customer') {
                window.location.replace('/Login');
                return;
            }

            // Thiết quân luật với SALES: Chỉ được vào /admin/bill
            if (userRole === 'Sales') {
                if (!currentPath.includes('/admin/bill')) {
                    alert("Truy cập bị từ chối! Nhân viên Sales chỉ được sử dụng tính năng Quản lý Hóa Đơn.");
                    window.location.replace('/Admin/Bill');
                }
            }

            // Thiết quân luật với INVENTORY: Chỉ được vào /admin/purchaseorder
            else if (userRole === 'Inventory') {
                if (!currentPath.includes('/admin/purchaseorder')) {
                    alert("Truy cập bị từ chối! Thủ kho chỉ được sử dụng tính năng Nhập Hàng.");
                    window.location.replace('/Admin/PurchaseOrder');
                }
            }
        });
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
<div class="modal fade" id="employeeProfileModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-header" style="background-color: #0a2551; color: white;">
                <h5 class="modal-title"><i class="fas fa-id-badge me-2"></i>Hồ sơ của tôi</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center p-4">
                <img src="https://ui-avatars.com/api/?name=Admin&background=1b45cf&color=fff&size=100"
                     id="profileAvatar" class="rounded-circle mb-3 shadow-sm" alt="Avatar">
                
                <h4 id="profileFullName" class="fw-bold mb-1" style="color: #0a2551;">Đang tải...</h4>
                <p><span id="profileRole" class="badge bg-primary px-3 py-2 rounded-pill">...</span></p>

                <ul class="list-group list-group-flush text-start mt-4">
                    <li class="list-group-item px-0">
                        <i class="fas fa-hashtag text-muted me-2"></i> <strong>Mã NV:</strong> <span id="profileEmpId" class="float-end"></span>
                    </li>
                    <li class="list-group-item px-0">
                        <i class="fas fa-phone text-muted me-2"></i> <strong>SĐT:</strong> <span id="profilePhone" class="float-end"></span>
                    </li>
                    <li class="list-group-item px-0">
                        <i class="fas fa-envelope text-muted me-2"></i> <strong>Email:</strong> <span id="profileEmail" class="float-end"></span>
                    </li>
                </ul>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary w-100" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
<script>
    // Hàm xem hồ sơ
    function viewMyProfile() {
    // Lấy mã nhân viên đang lưu trong trình duyệt
    const empId = localStorage.getItem('EmployeeID');
        
    if (!empId) {
    alert("Bạn đang đăng nhập bằng tài khoản không có mã nhân viên (VD: Admin hệ thống cũ)!");
    return;
    }

    // Gọi API get_employee(id) của ông
    fetch(`http://127.0.0.1:5000/employees/${empId}`)
    .then(res => res.json())
    .then(data => {
    // API fetchone bằng get_json_results trả về mảng, nên lấy data[0]
    if (data && data.length > 0) {
    const emp = data[0];
                    
    // Cập nhật giao diện
    document.getElementById('profileEmpId').innerText = emp.EmployeeID;
    document.getElementById('profileFullName').innerText = emp.FullName;
    document.getElementById('profileRole').innerText = emp.Role;
    document.getElementById('profilePhone').innerText = emp.Phone || 'Chưa cập nhật';
    document.getElementById('profileEmail').innerText = emp.Email || 'Chưa cập nhật';
                    
    // Đổi tên avatar theo chữ cái đầu
    document.getElementById('profileAvatar').src = `https://ui-avatars.com/api/?name=${emp.FullName}&background=1b45cf&color=fff&size=100`;

    // Hiển thị modal
    new bootstrap.Modal(document.getElementById('employeeProfileModal')).show();
    } else {
    alert("Không tìm thấy dữ liệu hồ sơ!");
    }
    })
    .catch(err => alert("Lỗi kết nối Server: " + err.message));
    }

    // Tiện tay làm luôn hàm Đăng xuất
    function handleLogout() {
    if(confirm("Bạn có chắc chắn muốn đăng xuất?")) {
    localStorage.clear(); // Xóa sạch bộ nhớ
    sessionStorage.clear();
    window.location.href = '/Login/Index'; // Chuyển về trang đăng nhập
    }
    }
</script>