@{
    ViewData["Title"] = "Đăng ký tài khoản";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CellTech</title>

    <link href="~/lib/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <div class="auth-wrapper">
        <div class="auth-card" style="max-width:460px">
            <div class="auth-header">
                <h2><i class="bi bi-phone"></i> CellTech</h2>
                <p>Tạo tài khoản mới</p>
            </div>
            <div class="auth-body">
                <form id="registerForm" onsubmit="handleRegister(event)">
                    <div id="errorMessage" class="auth-error"></div>

                    <input id="username" type="text" class="auth-input" placeholder="Tên đăng nhập" required autocomplete="username" />
                    <input id="fullname" type="text" class="auth-input" placeholder="Họ và tên" required />
                    <div class="row g-2">
                        <div class="col-6">
                            <input id="phone" type="text" class="auth-input" placeholder="Số điện thoại" required />
                        </div>
                        <div class="col-6">
                            <input id="email" type="email" class="auth-input" placeholder="Email" required />
                        </div>
                    </div>
                    <input id="address" type="text" class="auth-input" placeholder="Địa chỉ" required />
                    <input id="password" type="password" class="auth-input" placeholder="Mật khẩu" required autocomplete="new-password" />
                    <input id="confirmPassword" type="password" class="auth-input" placeholder="Xác nhận mật khẩu" required autocomplete="new-password" />

                    <button type="submit" class="auth-btn" id="registerBtn">
                        Tạo tài khoản
                    </button>

                    <div class="auth-footer">
                        Đã có tài khoản?
                        <a href="/Login/Index">Đăng nhập ngay</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function handleRegister(event) {
            event.preventDefault();

            const user = document.getElementById('username').value;
            const name = document.getElementById('fullname').value;
            const phone = document.getElementById('phone').value;
            const email = document.getElementById('email').value;
            const address = document.getElementById('address').value;
            const password = document.getElementById('password').value;
            const confirmPassword = document.getElementById('confirmPassword').value;
            const errorDiv = document.getElementById('errorMessage');
            const btn = document.getElementById('registerBtn');

            errorDiv.classList.remove('show');

            if (password !== confirmPassword) {
                errorDiv.innerText = 'Mật khẩu xác nhận không khớp!';
                errorDiv.classList.add('show');
                return;
            }

            if (password.length < 4) {
                errorDiv.innerText = 'Mật khẩu phải có ít nhất 4 ký tự!';
                errorDiv.classList.add('show');
                return;
            }

            btn.disabled = true;
            btn.textContent = 'Đang tạo tài khoản...';

            fetch('http://127.0.0.1:5000/auth/register', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    Username: user,
                    FullName: name,
                    Phone: phone,
                    Email: email,
                    Address: address,
                    Password: password
                })
            })
            .then(response => response.json().then(data => ({ status: response.status, body: data })))
            .then(result => {
                if (result.status === 200) {
                    alert('Đăng ký thành công! Vui lòng đăng nhập.');
                    window.location.href = '/Login/Index';
                } else {
                    errorDiv.innerText = result.body.mess || 'Có lỗi xảy ra khi đăng ký.';
                    errorDiv.classList.add('show');
                    btn.disabled = false;
                    btn.textContent = 'Tạo tài khoản';
                }
            })
            .catch(error => {
                console.error('Error:', error);
                errorDiv.innerText = 'Không thể kết nối đến máy chủ.';
                errorDiv.classList.add('show');
                btn.disabled = false;
                btn.textContent = 'Tạo tài khoản';
            });
        }
    </script>
</body>
</html>