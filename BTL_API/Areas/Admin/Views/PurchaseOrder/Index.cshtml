@{
    ViewData["Title"] = "Quản lý Phiếu nhập kho";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h2 class="mt-4" style="color: #0a2551; font-weight: 600;">Danh sách Phiếu nhập kho</h2>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Cửa hàng</a></li>
    <li class="breadcrumb-item active">Phiếu nhập kho</li>
</ol>

<div class="row mb-3 align-items-center">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white" style="color: #6c757d;"><i class="fas fa-filter" ></i></span>
            <select class="form-select border-start-0" aria-label="Filter Status" onchange="filterOrders()" id="filterStatus">
                <option selected>Tất cả trạng thái...</option>
                <option value="Completed">Đã nhập kho (Completed)</option>
                <option value="Processing">Đang vận chuyển (Shipping)</option>
                <option value="Draft">Bản nháp (Draft)</option>
            </select>
        </div>
    </div>

    <div class="col-md-8 d-flex justify-content-end gap-2">
        <div class="input-group" style="max-width: 250px;">
            <input type="text" class="form-control" placeholder="Tìm mã phiếu..." aria-label="Search" id="searchOrderInput" oninput="filterOrders()">
            <button class="btn btn-outline-secondary bg-white text-muted" type="button">
                <i class="fas fa-search"></i>
            </button>
        </div>
        
        <button class="btn btn-secondary text-white" title="Nhập Excel" style="background-color: #6c757d; border: none;">
            <i class="fas fa-file-import"></i>
        </button>
        <button class="btn btn-secondary text-white" title="Xuất Excel" style="background-color: #6c757d; border: none;">
            <i class="fas fa-file-export"></i>
        </button>
        
        <button class="btn text-white" title="Tạo phiếu nhập mới" style="background-color: #1b45cf; border: none;" onclick="openAddOrderModal()">
            <i class="fas fa-plus-circle fa-lg"></i> Nhập hàng
        </button>
    </div>
</div>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" width="100%" cellspacing="0">
                <thead style="background-color: #f4f6f9; color: #0a2551;">
                    <tr>
                     
                        <th width="12%">Mã Phiếu</th>
                        <th width="20%">Nhà cung cấp</th>
                        <th width="15%">Người lập phiếu</th>
                        <th width="15%">Ngày lập</th>
                        <th class="text-center" width="18%">Trạng thái</th>
                        <th class="text-center pe-3" width="15%">Hành động</th>
                    </tr>
                </thead>
                <tbody id="purchaseOrderTableBody">
                    <tr>
                        <td colspan="7" class="text-center text-muted py-4">
                            <i class="fas fa-spinner fa-spin me-2"></i> Đang tải dữ liệu...
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="card-footer bg-white py-3">
        <ul class="pagination justify-content-end mb-0">
            <li class="page-item disabled"><a class="page-link" href="#">Trước</a></li>
            <li class="page-item active"><a class="page-link" href="#" style="background-color: #1b45cf; border-color: #1b45cf;">1</a></li>
            <li class="page-item"><a class="page-link" href="#">Sau</a></li>
        </ul>
    </div>
</div>
<div class="modal fade" id="addOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-file-invoice me-2"></i>Tạo Phiếu Nhập Kho Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="fw-bold form-label">Mã Nhà cung cấp (SupplierID)</label>
                        <input type="text" class="form-control" id="addSupplierID" placeholder="VD: SUP1">
                    </div>
                    <div class="col-md-6">
                        <label class="fw-bold form-label">Mã Người lập phiếu (EmployeeID)</label>
                        <input type="text" class="form-control" id="addEmployeeID" placeholder="VD: EMP1">
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-4">
                    <h6 class="fw-bold text-success mb-0"><i class="fas fa-boxes me-2"></i>Chi Tiết Sản Phẩm Nhập</h6>
                    <button class="btn btn-sm btn-outline-success" onclick="addDetailRow()">
                        <i class="fas fa-plus"></i> Thêm dòng sản phẩm
                    </button>
                </div>
                
                <div id="orderDetailArea">
                </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary px-5" onclick="submitFullOrder()">Lưu Phiếu & Chi Tiết</button>
            </div>
        </div>
    </div>
</div>
// hien thi chi tiet don hang
<div class="modal fade" id="detailOrderModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="fas fa-list me-2"></i>Chi Tiết Phiếu Nhập: <span id="detailPoId"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <table class="table table-bordered table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Mã CTHĐ</th>
                            <th>Mã Biến thể (SP)</th>
                            <th class="text-center">Số lượng</th>
                            <th class="text-end">Giá nhập (VNĐ)</th>
                            <th class="text-end">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody id="detailOrderTableBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/Admin-purchase.js" asp-append-version="true"></script>
}