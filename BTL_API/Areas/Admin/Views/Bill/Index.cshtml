@{
    ViewData["Title"] = "Quản lý Đơn bán hàng";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h2 class="mt-4" style="color: #0a2551; font-weight: 600;">Danh sách Đơn hàng</h2>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Cửa hàng</a></li>
    <li class="breadcrumb-item active">Đơn bán hàng</li>
</ol>

<div class="row mb-3 align-items-center">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white" style="color: #6c757d;"><i class="fas fa-filter"></i></span>
            <select class="form-select border-start-0" aria-label="Filter" id="filterBill" onchange="executeBillSearch()">
                <option value="All" selected>Tất cả trạng thái...</option>
                <option value="Draft">Nháp (Draft)</option>
                <option value="Completed">Hoàn thành (Completed)</option>
                <option value="Cancelled">Đã hủy (Cancelled)</option>
            </select>
        </div>
    </div>

    <div class="col-md-8 d-flex justify-content-end gap-2">
        <div class="input-group" style="max-width: 250px;">
            <input type="text" class="form-control" placeholder="Tìm mã đơn..." aria-label="Search" id="billSearchInput" onkeyup="executeBillSearch()" onclick="excuteBillSearch()">
            <button class="btn btn-outline-secondary bg-white text-muted" type="button">
                <i class="fas fa-search"></i>
            </button>
        </div>
        
        <button class="btn btn-secondary text-white" title="Nhập dữ liệu" style="background-color: #6c757d; border: none;">
            <i class="fas fa-file-import"></i>
        </button>
        <button class="btn btn-secondary text-white" title="Xuất Excel" style="background-color: #6c757d; border: none;">
            <i class="fas fa-file-export"></i>
        </button>
        
        <button class="btn text-white" title="Tạo đơn mới" style="background-color: #1b45cf; border: none;"onclick="openAddBillModal()">
            <i class="fas fa-plus-circle fa-lg"></i>
        </button>
    </div>
</div>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" width="100%" cellspacing="0">
                <thead style="background-color: #f4f6f9; color: #0a2551;">
                    <tr>
                        
                        <th width="12%">Mã Đơn</th>
                        <th width="15%">Khách hàng</th>
                        <th width="15%">Nhân viên tạo</th>
                        <th width="15%">Ngày tạo đơn</th>
                        <th width="15%">Thanh toán</th>
                        <th width="15%">Tổng tiền</th>
                        <th class="text-center" width="13%">Trạng thái</th>
                        <th class="text-center pe-3" width="10%">Hành động</th>
                    </tr>
                </thead>
                <tbody id="billTableBody">
                   
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="card-footer bg-white py-3">
        <ul class="pagination justify-content-end mb-0" id="billPagination"></ul>
    </div>
</div>
<div class="modal fade" id="viewBillDetailModal" tabindex="-1" aria-labelledby="viewBillDetailModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow">

            <div class="modal-header text-white" style="background-color: #0a2551;">
                <h5 class="modal-title fw-bold" id="viewBillDetailModalLabel">
                    <i class="fas fa-receipt me-2"></i>Chi tiết Hóa Đơn: <span id="detailBillId" class="text-warning"></span>
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-4">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle">
                        <thead class="table-light text-center text-secondary">
                            <tr>
                                <th>Mã Sản Phẩm (Variant)</th>
                                <th>Số lượng</th>
                                <th class="text-end">Đơn giá</th>
                                <th class="text-end">Thành tiền</th>
                            </tr>
                        </thead>
                        <tbody id="billDetailTableBody">
                        </tbody>
                    </table>
                </div>

                <div class="d-flex justify-content-end mt-3 border-top pt-3">
                    <h5 class="mb-0">Tổng thanh toán: <span id="detailTotalPrice" class="text-danger fw-bold ms-2">0đ</span></h5>
                </div>
            </div>

            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Đóng</button>
            </div>

        </div>
    </div>
</div>
//tao don moi
<div class="modal fade" id="addBillModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="fas fa-cart-plus me-2"></i>Tạo Đơn Bán Hàng Mới</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="fw-bold form-label">Mã Khách Hàng</label>
                        <input type="text" class="form-control" id="addCustomerID" placeholder="Bỏ trống nếu vãng lai">
                    </div>
                    <div class="col-md-4">
                        <label class="fw-bold form-label">Mã Nhân Viên</label>
                        <input type="text" class="form-control" id="addEmployeeID">
                    </div>
                    <div class="col-md-4">
                        <label class="fw-bold form-label">Hình thức thanh toán</label>
                        <select class="form-select" id="addPayMethod">
                            <option value="Tiền mặt">Tiền mặt</option>
                            <option value="Chuyển khoản">Chuyển khoản</option>
                            <option value="Quẹt thẻ">Quẹt thẻ</option>
                        </select>
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3 border-bottom pb-2 mt-4">
                    <h6 class="fw-bold text-success mb-0"><i class="fas fa-box-open me-2"></i>Sản Phẩm Bán</h6>
                    <button class="btn btn-sm btn-outline-success" onclick="addBillDetailRow()">
                        <i class="fas fa-plus"></i> Thêm sản phẩm
                    </button>
                </div>
                
                <div id="billDetailArea">
                    </div>
            </div>
            <div class="modal-footer bg-light">
                <button type="button" class="btn btn-secondary px-4" data-bs-dismiss="modal">Hủy</button>
                <button type="button" class="btn btn-primary px-5" onclick="submitFullBill()">Tạo đơn & Xuất kho</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/Admin-bill.js" asp-append-version="true"></script>
}
<style>
    .pagination .page-link {
        color: #1b45cf;
        border: 1px solid #dee2e6;
        padding: 8px 16px;
    }
    .pagination .page-item.active .page-link {
        background-color: #1b45cf;
        border-color: #1b45cf;
        color: white;
    }
    .pagination .page-item.disabled .page-link {
        color: #6c757d;
        pointer-events: none;
        background-color: #f8f9fa;
    }
</style>