@{
    ViewData["Title"] = "Quản lý Sản phẩm";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h2 class="mt-4" style="color: #0a2551; font-weight: 600;">Danh sách Sản phẩm</h2>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Cửa hàng</a></li>
    <li class="breadcrumb-item active">Sản phẩm</li>
</ol>

<div class="row mb-3 align-items-center">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white" style="color: #6c757d;"><i class="fas fa-filter"></i></span>
            <select class="form-select border-start-0" id="filterBrand" onchange="executeProdSearch()">
                <option value="All" selected>Tất cả thương hiệu...</option>
                <option value="Apple">Apple</option>
                <option value="Samsung">Samsung</option>
                <option value="Asus">Asus</option>
                <option value="Acer">Acer</option>
                <option value="Dell">Dell</option>
                <option value="HP">HP</option>
                <option value="Lenovo">Lenovo</option>
                <option value="Sony">Sony</option>
                <option value="Xiaomi">Xiaomi</option>
                <option value="LG">LG</option>
            </select>
        </div>
    </div>

    <div class="col-md-8 d-flex justify-content-end gap-2">
        <div class="input-group" style="max-width: 250px;">
            <input type="text" class="form-control" placeholder="Tìm tên SP, Mã..." id="prodSearchInput" onkeyup="executeProdSearch()">
            <button class="btn btn-outline-secondary bg-white text-muted" type="button" onclick="executeProdSearch()">
                <i class="fas fa-search"></i>
            </button>
        </div>
        
        <button class="btn text-white" data-bs-toggle="modal" data-bs-target="#addProductModal" title="Thêm sản phẩm" style="background-color: #1b45cf; border: none;">
            <i class="fas fa-plus fa-lg me-1"></i> Thêm mới
        </button>
    </div>
</div>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" width="100%" cellspacing="0">
                <thead style="background-color: #f4f6f9; color: #0a2551;">
                    <tr>
                        <th width="10%">Mã SP</th>
                        <th width="15%">Hình ảnh</th>
                        <th width="30%">Tên sản phẩm</th>
                        <th width="15%">Thương hiệu</th>
                        <th class="text-center pe-3" width="15%">Hành động</th>
                    </tr>
                </thead>
                <tbody id="productTableBody">
                   </tbody>
            </table>
        </div>
    </div>
    
    <div class="card-footer bg-white py-3">
        <ul class="pagination pagination-prod justify-content-end mb-0">
        </ul>
    </div>
</div>

@* @await Html.PartialAsync("_AddProductModal") *@ 
@* @await Html.PartialAsync("_EditProductModal") *@
@await Html.PartialAsync("_VariantModal")
@section Scripts {
    <script src="~/js/Admin-prod.js" asp-append-version="true"></script>
}