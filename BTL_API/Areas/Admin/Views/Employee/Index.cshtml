@{
    ViewData["Title"] = "Quản lý Nhân viên";
    Layout = "~/Views/Shared/_Layout_Admin.cshtml";
}

<h2 class="mt-4" style="color: #0a2551; font-weight: 600;">Danh sách Nhân viên</h2>
<ol class="breadcrumb mb-4">
    <li class="breadcrumb-item"><a href="#" style="color: #1b45cf; text-decoration: none;">Nhân sự & Đối tác</a></li>
    <li class="breadcrumb-item active">Nhân viên</li>
</ol>

<div class="row mb-3 align-items-center">
    <div class="col-md-4">
        <div class="input-group">
            <span class="input-group-text bg-white" style="color: #6c757d;"><i class="fas fa-filter"></i></span>
            <select class="form-select border-start-0" aria-label="Filter Role">
                <option selected>Tất cả bộ phận...</option>
                <option value="Quản lý">Quản lý</option>
                <option value="Bán hàng">Bán hàng</option>
                <option value="Thủ kho">Thủ kho</option>
                <option value="Thu ngân">Thu ngân</option>
                <option value="Kỹ thuật">Kỹ thuật</option>
            </select>
        </div>
    </div>

    <div class="col-md-8 d-flex justify-content-end gap-2">
        <div class="input-group" style="max-width: 250px;">
            <input type="text" class="form-control" placeholder="Tìm tên, SĐT..." aria-label="Search">
            <button class="btn btn-outline-secondary bg-white text-muted" type="button">
                <i class="fas fa-search"></i>
            </button>
        </div>
        
        <button class="btn btn-secondary text-white" title="Xuất danh sách Excel" style="background-color: #6c757d; border: none;">
            <i class="fas fa-file-export"></i> Xuất file
        </button>
        
        <button class="btn text-white" data-bs-toggle="modal" data-bs-target="#addEmployeeModal" title="Thêm nhân viên" title="Thêm nhân viên" style="background-color: #1b45cf; border: none;">
            <i class="fas fa-user-plus fa-lg me-1"></i> Thêm mới
        </button>
    </div>
</div>

<div class="card mb-4 shadow-sm border-0">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" width="100%" cellspacing="0">
                <thead style="background-color: #f4f6f9; color: #0a2551;">
                    <tr>
                        <th class="ps-3" width="5%"><input type="checkbox" class="form-check-input"></th>
                        <th width="10%">Mã NV</th>
                        <th width="20%">Họ và Tên</th>
                        <th width="15%">Số điện thoại</th>
                        <th width="20%">Email</th>
                        <th class="text-center" width="15%">Bộ phận</th>
                        <th class="text-center pe-3" width="15%">Hành động</th>
                    </tr>
                </thead>
                <tbody id="employeeTableBody">
                   
                </tbody>
            </table>
        </div>
    </div>
    
    <div class="card-footer bg-white py-3">
        <ul class="pagination justify-content-end mb-0">
            <li class="page-item disabled"><a class="page-link" href="#">Trước</a></li>
            <li class="page-item active"><a class="page-link" href="#" style="background-color: #1b45cf; border-color: #1b45cf;">1</a></li>
            <li class="page-item"><a class="page-link" href="#">Sau</a></li>
        </ul>
    </div>
</div>
@await Html.PartialAsync("_AddEmployeeModal")
@section Scripts {
    <script src="~/js/Admin-emp.js" asp-append-version="true"></script>
}