<div class="modal fade" id="editEmployeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header" style="background-color: #1b45cf; color: white;">
                <h5 class="modal-title"><i class="fas fa-user-edit me-2"></i>Cập Nhật Thông Tin Nhân Viên</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="formEditEmployee">
                    <input type="hidden" id="editEmployeeId">
                    
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Họ và Tên</label>
                            <input type="text" class="form-control" id="editFullName" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Chức vụ</label>
                            <select class="form-select" id="editRole">
                                <option value="Bán hàng">Bán hàng</option>
                                <option value="Thu ngân">Thu ngân</option>
                                <option value="Thủ kho">Thủ kho</option>
                                <option value="Kỹ thuật">Kỹ thuật</option>
                                <option value="Quản lý">Quản lý</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Số điện thoại</label>
                            <input type="text" class="form-control" id="editPhone" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control" id="editEmail" required>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
                <button type="button" class="btn text-white" style="background-color: #0a2551;" onclick="submitEditEmployee()">Lưu Thay Đổi</button>
            </div>
        </div>
    </div>
</div>